<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="Searchlight.Views.MainView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:conv="using:Searchlight.Converters"
    xmlns:controls="using:Searchlight.Controls"
    xmlns:models="using:Searchlight.Models"
    mc:Ignorable="d">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:StringToVisibilityConverter x:Key="StringToVis" />
        <conv:StringOrDashConverter x:Key="StringOrDash" />
        <conv:FriendlyDateConverter x:Key="FriendlyDate" />
    </UserControl.Resources>

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Custom title bar (drag region). The default system title bar is removed
             via ExtendsContentIntoTitleBar in MainWindow, so this dark strip fills
             that space and carries the single app label. Right padding reserves room
             for the min/max/close caption buttons that overlay the top-right. -->
        <Grid x:Name="AppTitleBar" Grid.Row="0" Height="40" Padding="16,0,150,0">
            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                <!-- UAC shield: shown only when the app runs elevated, like Windows Terminal.
                     Placed at the far left (before the app icon), drawn white to stay subtle.
                     OneTime x:Bind — elevation is fixed for the process lifetime. -->
                <FontIcon Glyph="&#xEA18;" FontSize="14" Foreground="White"
                          VerticalAlignment="Center"
                          ToolTipService.ToolTip="Running as administrator"
                          Visibility="{x:Bind IsElevated, Converter={StaticResource BoolToVis}}" />
                <Image Source="{x:Bind AppIconSource}" Width="18" Height="18"
                       VerticalAlignment="Center" />
                <TextBlock Style="{StaticResource BodyStrongTextBlockStyle}"
                           VerticalAlignment="Center">
                    <Run Text="Searchlight" />
                    <Run Text="   Historical Session Viewer"
                         Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                         FontWeight="Normal" />
                </TextBlock>
            </StackPanel>

            <!-- Settings gear, right-aligned but left of the caption buttons (reserved
                 by the 150px right padding). Opens a flyout with the resume behavior toggle. -->
            <Button HorizontalAlignment="Right" VerticalAlignment="Center"
                    Background="Transparent" BorderThickness="0"
                    Padding="8" ToolTipService.ToolTip="Settings">
                <FontIcon Glyph="&#xE713;" FontSize="16" />
                <Button.Flyout>
                    <Flyout>
                        <StackPanel Width="320" Spacing="8">
                            <TextBlock Text="Settings"
                                       Style="{StaticResource SubtitleTextBlockStyle}" />
                            <TextBlock Text="Reuse my existing terminal window"
                                       Style="{StaticResource BodyStrongTextBlockStyle}"
                                       TextWrapping="Wrap" />
                            <TextBlock TextWrapping="Wrap"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Text="When on, resuming a session opens a new tab in your most-recently-used Windows Terminal window (a new one is created only if none is open). When off, each resume opens its own new window." />
                            <ToggleSwitch MinWidth="0"
                                          OnContent="On" OffContent="Off"
                                          IsOn="{x:Bind ViewModel.Settings.Current.UseSharedTerminalWindow, Mode=TwoWay}" />

                            <!-- Elevation opt-in. Needed when the user's main Terminal
                                 runs as Admin: matching integrity level lets `wt -w`
                                 reuse that window. Flipping on relaunches elevated. -->
                            <TextBlock Text="Run as administrator"
                                       Style="{StaticResource BodyStrongTextBlockStyle}"
                                       TextWrapping="Wrap" Margin="0,8,0,0" />
                            <TextBlock TextWrapping="Wrap"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Text="Turn on if your main Terminal runs as Administrator. The app restarts elevated (one UAC prompt) so resumed tabs can share your Admin Terminal window. Turning off applies on the next launch." />
                            <ToggleSwitch MinWidth="0"
                                          OnContent="On" OffContent="Off"
                                          IsOn="{x:Bind ViewModel.Settings.Current.RunElevated, Mode=TwoWay}" />

                            <!-- Yolo opt-in. Appends the yolo flag to resume so the
                                 resumed session auto-approves all tool actions. -->
                            <TextBlock Text="Resume with --yolo"
                                       Style="{StaticResource BodyStrongTextBlockStyle}"
                                       TextWrapping="Wrap" Margin="0,8,0,0" />
                            <TextBlock TextWrapping="Wrap"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Text="When on, resuming a session appends --yolo so it runs with all tool approvals auto-granted (no per-action confirmation). Off by default." />
                            <ToggleSwitch MinWidth="0"
                                          OnContent="On" OffContent="Off"
                                          IsOn="{x:Bind ViewModel.Settings.Current.AppendYolo, Mode=TwoWay}" />
                        </StackPanel>
                    </Flyout>
                </Button.Flyout>
            </Button>
        </Grid>

        <!-- Search + refresh -->
        <Grid Grid.Row="1" Padding="16,4,16,8" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBox Grid.Column="0"
                     PlaceholderText="Search name, id, folder, branch, prompt…"
                     Text="{x:Bind ViewModel.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     VerticalAlignment="Center"
                     HorizontalAlignment="Stretch" />

            <ProgressRing Grid.Column="1"
                          IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                          Width="20" Height="20"
                          VerticalAlignment="Center" />

            <Button Grid.Column="2"
                    Command="{x:Bind ViewModel.RefreshCommand}"
                    VerticalAlignment="Center"
                    ToolTipService.ToolTip="Refresh">
                <FontIcon Glyph="&#xE72C;" FontSize="16" />
            </Button>
        </Grid>

        <!-- Body: list (left) + details (right) -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="380" MinWidth="300" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" MinWidth="360" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Session list. FlowDirection is flipped to RightToLeft so the native
                 vertical scrollbar renders on the list's LEFT edge (next to the tick
                 rail, away from the details pane). The item template root and group
                 header restore LeftToRight so their content still reads normally. -->
            <ListView Grid.Column="1"
                      x:Name="SessionList"
                      FlowDirection="RightToLeft"
                      SelectedItem="{x:Bind ViewModel.SelectedSession, Mode=TwoWay}"
                      SelectionMode="Single"
                      DoubleTapped="OnSessionDoubleTapped"
                      Padding="8,0,8,8">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Padding" Value="12,10" />
                        <Setter Property="Margin" Value="0,2" />
                        <Setter Property="CornerRadius" Value="6" />
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:SessionInfo">
                        <Grid ColumnSpacing="8" FlowDirection="LeftToRight">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Spacing="2">
                                <TextBlock Text="{x:Bind DisplayName}"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="{x:Bind Cwd, Converter={StaticResource StringOrDash}}"
                                           FontSize="12"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           TextTrimming="CharacterEllipsis"
                                           MaxLines="1" />
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="{x:Bind Branch, Converter={StaticResource StringOrDash}}"
                                               FontSize="11"
                                               Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                               TextTrimming="CharacterEllipsis"
                                               MaxLines="1" />
                                    <TextBlock Text="•"
                                               FontSize="11"
                                               Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                    <TextBlock Text="{x:Bind UpdatedAt, Converter={StaticResource FriendlyDate}}"
                                               FontSize="11"
                                               Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Top">
                                <!-- Note-presence badge: outlined shape + glyph + "Notes" text
                                     (distinguished by shape, not color) so the row shows at a
                                     glance that it carries a saved note. -->
                                <Border Background="Transparent" BorderThickness="1"
                                        BorderBrush="{ThemeResource TextFillColorSecondaryBrush}"
                                        CornerRadius="4" Padding="6,2"
                                        Visibility="{x:Bind HasNote, Converter={StaticResource BoolToVis}}">
                                    <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                        <FontIcon Glyph="&#xE70B;" FontSize="10" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        <TextBlock Text="Notes" FontSize="10" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                </Border>
                                <Border Background="{ThemeResource SystemFillColorSuccessBackgroundBrush}"
                                        CornerRadius="4" Padding="6,2"
                                        Visibility="{x:Bind IsInUse, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="In use" FontSize="10"
                                               Foreground="{ThemeResource SystemFillColorSuccessBrush}" />
                                </Border>
                                <!-- Client badges: distinguished by SHAPE (filled vs outlined)
                                     + GLYPH + TEXT, not color alone, so they stay legible without
                                     color perception. CLI = filled + command-prompt glyph;
                                     App = outlined + apps glyph. -->
                                <Border Background="#4A5BD6"
                                        CornerRadius="4" Padding="6,2"
                                        Visibility="{x:Bind IsCliClient, Converter={StaticResource BoolToVis}}">
                                    <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                        <FontIcon Glyph="&#xE756;" FontSize="10" Foreground="White" />
                                        <TextBlock Text="CLI" FontSize="10" Foreground="White" />
                                    </StackPanel>
                                </Border>
                                <Border Background="Transparent" BorderThickness="1" BorderBrush="#3AC0D4"
                                        CornerRadius="4" Padding="6,2"
                                        Visibility="{x:Bind IsAppClient, Converter={StaticResource BoolToVis}}">
                                    <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                        <FontIcon Glyph="&#xE71D;" FontSize="10" Foreground="#3AC0D4" />
                                        <TextBlock Text="App" FontSize="10" Foreground="#3AC0D4" />
                                    </StackPanel>
                                </Border>
                                <Border Background="{ThemeResource LayerFillColorDefaultBrush}"
                                        CornerRadius="4" Padding="6,2">
                                    <TextBlock Text="{x:Bind Kind}" FontSize="10"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </Border>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
                <ListView.GroupStyle>
                    <GroupStyle>
                        <GroupStyle.HeaderTemplate>
                            <DataTemplate x:DataType="models:SessionGroup">
                                <Border Padding="4,12,4,4" FlowDirection="LeftToRight"
                                        Background="Transparent"
                                        PointerWheelChanged="OnGroupHeaderPointerWheelChanged">
                                    <TextBlock Text="{x:Bind Key}"
                                               FontWeight="SemiBold"
                                               FontSize="12"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </Border>
                            </DataTemplate>
                        </GroupStyle.HeaderTemplate>
                    </GroupStyle>
                </ListView.GroupStyle>
            </ListView>

            <!-- Compact tick rail: an always-visible column of short group labels
                 that acts like a second scrollbar — clicking a tick jumps the list
                 straight to that group. Pinned to the far-left edge (col 0). -->
            <ScrollViewer Grid.Column="0"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="2,0,2,8"
                          Background="{ThemeResource LayerFillColorDefaultBrush}">
                <ItemsControl ItemsSource="{x:Bind ViewModel.SessionGroups, Mode=OneWay}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:SessionGroup">
                            <Button Click="OnRailTickClick"
                                    Tag="{x:Bind}"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="6,4"
                                    Margin="0,1"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Center"
                                    ToolTipService.ToolTip="{x:Bind Key}">
                                <TextBlock Text="{x:Bind ShortKey}"
                                           FontSize="11"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- Divider -->
            <Border Grid.Column="2" Width="1"
                    Background="{ThemeResource DividerStrokeColorDefaultBrush}" />

            <!-- Details pane -->
            <Grid Grid.Column="3">
                <!-- Empty state -->
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8"
                            Visibility="{x:Bind ViewModel.Details.HasSession, Mode=OneWay, Converter={StaticResource BoolToVis}, ConverterParameter=invert}">
                    <FontIcon Glyph="&#xE7C3;" FontSize="40"
                              Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                    <TextBlock Text="Select a session"
                               Style="{StaticResource BodyStrongTextBlockStyle}"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="Details, checkpoints, snapshots, and todos appear here."
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               HorizontalAlignment="Center" TextAlignment="Center" />
                </StackPanel>

                <!-- Details content: pinned header + scrolling body -->
                <Grid Visibility="{x:Bind ViewModel.Details.HasSession, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Pinned title + Resume (stays visible while body scrolls) -->
                    <Grid Grid.Row="0" ColumnSpacing="12" Padding="20,16,20,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Text="{x:Bind ViewModel.Details.Session.DisplayName, Mode=OneWay}"
                                       Style="{StaticResource TitleTextBlockStyle}"
                                       TextTrimming="CharacterEllipsis" MaxLines="2" />
                            <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                <TextBlock Text="{x:Bind ViewModel.Details.Session.Id, Mode=OneWay}"
                                           FontFamily="Consolas" FontSize="12"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           IsTextSelectionEnabled="True"
                                           VerticalAlignment="Center" />
                                <Button Command="{x:Bind ViewModel.Details.CopyIdCommand}"
                                        Padding="4" MinWidth="0"
                                        Background="Transparent" BorderThickness="0"
                                        VerticalAlignment="Center"
                                        ToolTipService.ToolTip="Copy session ID">
                                    <FontIcon Glyph="&#xE8C8;" FontSize="12" />
                                </Button>
                            </StackPanel>
                            <!-- Note-presence badge: text label (not icon-only) so it reads
                                 clearly. Shown when the selected session has a saved note. -->
                            <Border Background="Transparent" BorderThickness="1"
                                    BorderBrush="{ThemeResource TextFillColorSecondaryBrush}"
                                    CornerRadius="4" Padding="6,2" Margin="0,2,0,0"
                                    HorizontalAlignment="Left"
                                    Visibility="{x:Bind ViewModel.SelectedHasNote, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                                <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                    <FontIcon Glyph="&#xE70B;" FontSize="10" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <TextBlock Text="Has notes" FontSize="10" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8"
                                    VerticalAlignment="Top">
                                        <!-- Notes toggle: shows/hides the optional Notes pane. Text
                                             label (not icon-only) per the accessibility-first rule;
                                             the label reads "Show notes" / "Hide notes" to match state. -->
                                        <Button Command="{x:Bind ViewModel.ToggleNotesPaneCommand}"
                                                VerticalAlignment="Stretch"
                                                AutomationProperties.Name="Toggle notes pane"
                                                ToolTipService.ToolTip="Show or hide the notes pane">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <FontIcon Glyph="&#xE70B;" FontSize="14" />
                                                <TextBlock Text="{x:Bind ViewModel.NotesPaneToggleLabel, Mode=OneWay}" />
                                            </StackPanel>
                                        </Button>
                                        <!-- Rename uses a TEXT label (accessibility: no icon-only
                                             affordance). Opens a small flyout with a text box editing
                                             the effective title; empty input reverts to the default. -->
                                        <Button VerticalAlignment="Stretch"
                                                ToolTipService.ToolTip="Rename this session">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <FontIcon Glyph="&#xE8AC;" FontSize="14" />
                                                <TextBlock Text="Rename" />
                                            </StackPanel>
                                            <Button.Flyout>
                                                <Flyout x:Name="RenameFlyout">
                                                    <StackPanel Spacing="12" MinWidth="280">
                                                        <TextBlock Text="Rename session"
                                                                   Style="{StaticResource BodyStrongTextBlockStyle}" />
                                                        <TextBox Header="Display name"
                                                                 Text="{x:Bind ViewModel.RenameDraft, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                 AcceptsReturn="False" />
                                                        <TextBlock Text="Leave blank to restore the automatic name."
                                                                   TextWrapping="Wrap" FontSize="12"
                                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                                            <Button Content="Save" Style="{StaticResource AccentButtonStyle}"
                                                                    Click="OnRenameSaveClick" />
                                                            <Button Content="Reset to default"
                                                                    Click="OnRenameResetClick"
                                                                    IsEnabled="{x:Bind ViewModel.SelectedHasCustomName, Mode=OneWay}" />
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Flyout>
                                            </Button.Flyout>
                                        </Button>
                                        <!-- Pin/Unpin use a TEXT label (not an icon-only affordance) for
                                 accessibility: pin glyphs are ambiguous, so a word makes the action
                                 unmistakable. Exactly one shows, toggled by the observable
                                 SelectedIsPinned so it flips live on pin/unpin. -->
                            <Button Command="{x:Bind ViewModel.TogglePinCommand}"
                                    VerticalAlignment="Stretch"
                                    Visibility="{x:Bind ViewModel.SelectedIsPinned, Mode=OneWay, Converter={StaticResource BoolToVis}, ConverterParameter=invert}">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE718;" FontSize="14" />
                                    <TextBlock Text="Pin" />
                                </StackPanel>
                            </Button>
                            <Button Command="{x:Bind ViewModel.TogglePinCommand}"
                                    VerticalAlignment="Stretch"
                                    Visibility="{x:Bind ViewModel.SelectedIsPinned, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE77A;" FontSize="14" />
                                    <TextBlock Text="Unpin" />
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource AccentButtonStyle}"
                                    Command="{x:Bind ViewModel.Details.ResumeCommand}"
                                    VerticalAlignment="Stretch">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE768;" FontSize="14" />
                                    <TextBlock Text="Resume" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <ScrollViewer Grid.Row="1" Padding="20,0,20,16">
                        <StackPanel Spacing="16">
                        <!-- Fields -->
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1" CornerRadius="8" Padding="16">
                            <StackPanel Spacing="10">
                                <Grid ColumnSpacing="16" RowSpacing="10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Folder" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{x:Bind ViewModel.Details.Session.Cwd, Mode=OneWay, Converter={StaticResource StringOrDash}}" IsTextSelectionEnabled="True" TextWrapping="Wrap" />

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Branch" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{x:Bind ViewModel.Details.Session.Branch, Mode=OneWay, Converter={StaticResource StringOrDash}}" />

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Model" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{x:Bind ViewModel.Details.Session.Model, Mode=OneWay, Converter={StaticResource StringOrDash}}" />

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Reasoning" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{x:Bind ViewModel.Details.Session.ReasoningEffort, Mode=OneWay, Converter={StaticResource StringOrDash}}" />

                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Version" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{x:Bind ViewModel.Details.Session.CopilotVersion, Mode=OneWay, Converter={StaticResource StringOrDash}}" />

                                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Updated" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <TextBlock Grid.Row="5" Grid.Column="1" Text="{x:Bind ViewModel.Details.Session.UpdatedAt, Mode=OneWay, Converter={StaticResource FriendlyDate}}" />

                                    <TextBlock Grid.Row="6" Grid.Column="0" Text="First prompt" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <TextBlock Grid.Row="6" Grid.Column="1" Text="{x:Bind ViewModel.Details.Session.FirstPromptPreview, Mode=OneWay, Converter={StaticResource StringOrDash}}" TextWrapping="Wrap" MaxLines="24" TextTrimming="CharacterEllipsis" />

                                    <TextBlock Grid.Row="7" Grid.Column="0" Text="Client" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <TextBlock Grid.Row="7" Grid.Column="1" Text="{x:Bind ViewModel.Details.Session.ClientNameRaw, Mode=OneWay}" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Checkpoints -->
                        <StackPanel Spacing="8">
                            <TextBlock Text="Checkpoints" Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <ItemsControl ItemsSource="{x:Bind ViewModel.Details.Checkpoints}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="models:CheckpointInfo">
                                        <Grid ColumnSpacing="10" Padding="0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Background="{ThemeResource LayerFillColorDefaultBrush}" CornerRadius="4" Padding="6,2" VerticalAlignment="Top">
                                                <TextBlock Text="{x:Bind Number}" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                            </Border>
                                            <TextBlock Grid.Column="1" Text="{x:Bind Title, Converter={StaticResource StringOrDash}}" TextWrapping="Wrap" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock Text="No checkpoints." FontSize="12"
                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                       Visibility="{x:Bind ViewModel.Details.Session.HasCheckpoints, Mode=OneWay, Converter={StaticResource BoolToVis}, ConverterParameter=invert}" />
                        </StackPanel>

                        <!-- Snapshots -->
                        <StackPanel Spacing="8">
                            <TextBlock Text="Status snapshots" Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <ItemsControl ItemsSource="{x:Bind ViewModel.Details.Snapshots}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="models:SnapshotInfo">
                                        <Grid ColumnSpacing="10" Padding="0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="150" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{x:Bind Timestamp, Converter={StaticResource FriendlyDate}}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                            <TextBlock Grid.Column="1" Text="{x:Bind SourceTrigger, Converter={StaticResource StringOrDash}}" FontSize="12" TextTrimming="CharacterEllipsis" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <!-- Todos -->
                        <StackPanel Spacing="8">
                            <TextBlock Text="Todos" Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <ItemsControl ItemsSource="{x:Bind ViewModel.Details.Todos}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="models:SessionTodo">
                                        <Grid ColumnSpacing="10" Padding="0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="90" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" Background="{ThemeResource LayerFillColorDefaultBrush}" CornerRadius="4" Padding="6,2" VerticalAlignment="Top" HorizontalAlignment="Left">
                                                <TextBlock Text="{x:Bind Status}" FontSize="10" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                            </Border>
                                            <TextBlock Grid.Column="1" Text="{x:Bind Title}" TextWrapping="Wrap" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Grid>

            <!-- Divider before the optional Notes pane (collapses with the pane). -->
            <Border Grid.Column="4" Width="1"
                    Background="{ThemeResource DividerStrokeColorDefaultBrush}"
                    Visibility="{x:Bind ViewModel.IsNotesPaneVisible, Mode=OneWay, Converter={StaticResource BoolToVis}}" />

            <!-- Optional Notes pane: free-form, unformatted per-session notes,
                 autosaved to a sidecar file. Its Auto column shrinks to zero width
                 when the pane is hidden (the content collapses). A plain multiline
                 TextBox with a real "Notes" heading and AutomationProperties.Name —
                 no icon-only affordance — per the accessibility-first design. -->
            <Grid Grid.Column="5" Width="320"
                  Visibility="{x:Bind ViewModel.IsNotesPaneVisible, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Spacing="2" Padding="16,16,16,8">
                    <TextBlock Text="Notes" Style="{StaticResource BodyStrongTextBlockStyle}" />
                    <TextBlock Text="Saved automatically for this session."
                               FontSize="12" TextWrapping="Wrap"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>

                <TextBox Grid.Row="1" Margin="16,0,16,16"
                         Text="{x:Bind ViewModel.SelectedNotes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         IsEnabled="{x:Bind ViewModel.Details.HasSession, Mode=OneWay}"
                         PlaceholderText="Write notes about this session…"
                         AcceptsReturn="True" TextWrapping="Wrap"
                         FontFamily="Consolas"
                         VerticalAlignment="Stretch" HorizontalAlignment="Stretch"
                         VerticalContentAlignment="Top"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         AutomationProperties.Name="Session notes" />
            </Grid>
        </Grid>

        <!-- Status bar: session count (left, mirrors the list pane) + most-recent action (right, full text, right-aligned, selectable) -->
        <Border Grid.Row="3" Padding="16,8"
                Background="{ThemeResource LayerFillColorDefaultBrush}"
                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0">
            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6"
                            VerticalAlignment="Center">
                    <TextBlock Text="{x:Bind ViewModel.VisibleCount, Mode=OneWay}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" />
                    <TextBlock Text="of" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" />
                    <TextBlock Text="{x:Bind ViewModel.TotalCount, Mode=OneWay}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" />
                    <TextBlock Text="sessions" Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12" />
                </StackPanel>

                <TextBlock Grid.Column="1"
                           Text="{x:Bind ViewModel.Details.LastActionText, Mode=OneWay}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" FontSize="12"
                           TextWrapping="Wrap" IsTextSelectionEnabled="True"
                           HorizontalAlignment="Right" TextAlignment="Right"
                           VerticalAlignment="Center" Margin="0,0,16,0" />
            </Grid>
        </Border>

        <!-- Bottom-right resize grip: an oversized transparent grab target (VS Code pixelated-triangle
             style) declared after the footer Border so it renders on top of the same Row 3 cell. The
             ResizeGrip control shows the diagonal NWSE resize cursor on hover so the corner clearly
             reads as grabbable; the 28x28 transparent square makes it easy to hit without pixel-hunting,
             while the dot triangle stays visually tucked in the corner. The dot Canvas is
             IsHitTestVisible=False so only the container handles PointerPressed. -->
        <controls:ResizeGrip Grid.Row="3" x:Name="ResizeGrip"
              Width="28" Height="28"
              HorizontalAlignment="Right" VerticalAlignment="Bottom"
              Background="Transparent"
              PointerPressed="OnResizeGripPressed"
              PointerMoved="OnResizeGripMoved"
              PointerReleased="OnResizeGripReleased"
              PointerCaptureLost="OnResizeGripCaptureLost"
              ToolTipService.ToolTip="Drag to resize">
            <Canvas IsHitTestVisible="False" Width="28" Height="28">
                <!-- Bottom row (3 dots) -->
                <Rectangle Canvas.Left="15" Canvas.Top="23" Width="2.5" Height="2.5"
                           Fill="{ThemeResource TextFillColorSecondaryBrush}" />
                <Rectangle Canvas.Left="19" Canvas.Top="23" Width="2.5" Height="2.5"
                           Fill="{ThemeResource TextFillColorSecondaryBrush}" />
                <Rectangle Canvas.Left="23" Canvas.Top="23" Width="2.5" Height="2.5"
                           Fill="{ThemeResource TextFillColorSecondaryBrush}" />
                <!-- Middle row (2 dots) -->
                <Rectangle Canvas.Left="19" Canvas.Top="19" Width="2.5" Height="2.5"
                           Fill="{ThemeResource TextFillColorTertiaryBrush}" />
                <Rectangle Canvas.Left="23" Canvas.Top="19" Width="2.5" Height="2.5"
                           Fill="{ThemeResource TextFillColorTertiaryBrush}" />
                <!-- Top dot (1) -->
                <Rectangle Canvas.Left="23" Canvas.Top="15" Width="2.5" Height="2.5"
                           Fill="{ThemeResource TextFillColorTertiaryBrush}" />
            </Canvas>
        </controls:ResizeGrip>
    </Grid>
</UserControl>
